# CST working files (large, regenerated each run)
working/
working.cst
test/
test.cst
test_gold/
exports/

# NIR pipeline transient artifacts (regenerated by smoke tests / agent runs)
nir/working_default_*/
nir/verification_run/
nir/drude_probe/
nir/results_*.tsv
nir/*.log

# Per-iteration CST projects under runs/ -- large binaries, regeneratable.
# CSVs, JSON records, and the report under runs/ ARE versioned.
runs/**/working_*.cst
runs/**/working_*/

# Slide-deck build output (regeneratable from build_slides.js + the PNG):
#   - node_modules/   pulled in by `npm install pptxgenjs`
#   - slide-*.jpg     intermediate images from PDF rasterization (visual QA only)
# We DO commit the .pptx and .pdf themselves -- those are the deliverables.
runs/node_modules/
runs/slide-*.jpg

# Python
__pycache__/
*.pyc
*.pyo
.eggs/
*.egg-info/

# Environment
.env
*.env

# IDE
.vscode/
.idea/

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Reports (regenerated by agent)
optimization_report.png
